# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployer account (fund via https://friendbot.stellar.org)
DEPLOYER_SECRET_KEY=S...

# Contract IDs (populated after deployment by scripts/deploy.sh)
MIXER_POOL_CONTRACT_ID=
RELAYER_REGISTRY_CONTRACT_ID=

# Pool Configuration
POOL_DENOMINATION=10000000000     # 100 XLM in stroops (1 XLM = 10^7 stroops)
POOL_MAX_FEE=1000000000           # 10 XLM max relayer fee
POOL_TREE_DEPTH=20                # Merkle tree depth (2^20 = ~1M deposits)
POOL_ROOT_HISTORY_SIZE=500        # Root history window

# Relayer Registry
RELAYER_MAX_FEE_BPS=100           # Max relayer fee: 1% (100 basis points)

# Token contract (XLM SAC address — set after wrapping native XLM)
TOKEN_CONTRACT_ID=

# Indexer Configuration
INDEXER_API_PORT=3001
INDEXER_POLL_INTERVAL_SECS=5
INDEXER_DATABASE_URL=postgres://localhost:5432/caligo
